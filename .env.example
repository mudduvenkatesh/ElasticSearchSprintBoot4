# ============================================================
# Elastic Cloud credentials
# Copy to .env, fill in values, never commit .env to git.
# ============================================================

# Cloud ID — Elastic Cloud console → Deployments → Copy Cloud ID
ELASTIC_CLOUD_ID=my-cluster:dXMtZWFzdC0xLmF3cy5mb3VuZC5pbyRhYmMxMjMkZGVmNDU2

# API Key — Kibana → Stack Management → API Keys → Create API key
# The value shown in the UI is already the base64-encoded id:key string.
ELASTIC_API_KEY=VnVhQ2ZHY0JDZGJrUW0tZTVhT3g6dWkybHAyYXhUTm1zeWFrdzl0dk5udw==

# HTTPS endpoint — Elastic Cloud console → Deployments → Elasticsearch → Copy endpoint
# Used only by Spring Boot's health-check binding, not by the custom client bean.
ELASTIC_ENDPOINT=https://abc123.us-east-1.aws.elastic-cloud.com:443

# Alternative basic auth (comment out ELASTIC_API_KEY above if using these)
# ELASTIC_USERNAME=elastic
# ELASTIC_PASSWORD=your-password
