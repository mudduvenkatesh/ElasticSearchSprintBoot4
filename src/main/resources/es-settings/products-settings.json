{
  "index": {
    "number_of_shards": 1,
    "number_of_replicas": 1
  },
  "analysis": {
    "analyzer": {
      "custom_english": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": ["lowercase", "english_stemmer", "english_stop"]
      }
    },
    "filter": {
      "english_stemmer": {
        "type": "stemmer",
        "language": "english"
      },
      "english_stop": {
        "type": "stop",
        "stopwords": "_english_"
      }
    }
  }
}
